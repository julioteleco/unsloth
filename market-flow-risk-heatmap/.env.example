# Copy this file to .env and fill in values as needed.
# All keys are OPTIONAL. The system degrades gracefully when they are absent.

# FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html)
# If omitted, the system runs on yfinance data only.
FRED_API_KEY=

# Optional: override the default data directory (defaults to ./data)
# MFRH_DATA_DIR=

# Optional: cache TTL in minutes for downloaded data (default 30)
# MFRH_CACHE_TTL_MIN=30
